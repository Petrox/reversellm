# reversellm environment file
# Copy to /etc/reversellm/<instance-name>.env
#
# Example: /etc/reversellm/port9000.env for reversellm@port9000

# Listen address (use 127.0.0.1:7888 for localhost-only)
LISTEN_ADDR=0.0.0.0:7888

# Comma-separated backend addresses (required)
BACKENDS=host1.local:8000,host2.local:8000

# Routing mode: sticky-rr, round-robin, or hash
MODE=sticky-rr

# Sticky table TTL (how long hash->backend mappings persist)
STICKY_TTL=12h

# Max sticky table entries before LRU eviction
STICKY_MAX=1000

# Characters from each end of message for fingerprint
PREFIX_LENGTH=256

# Backend health check endpoint
HEALTH_PATH=/health

# Health check interval
HEALTH_INTERVAL=10s

# Maximum request body size in bytes (16 MB = 16777216)
MAX_REQUEST_SIZE=16777216

# Per-IP rate limit (requests/second, 0 = unlimited)
RATE_LIMIT=0
